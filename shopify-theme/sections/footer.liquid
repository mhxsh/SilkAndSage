{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}

<footer class="ss-footer">
  <div class="ss-container">
    <div class="ss-footer__grid">
      <!-- Column 1: Brand Logo and Slogan -->
      <div class="ss-footer__col">
        <h3 class="ss-footer__logo">Silk & Sage</h3>
        <p class="ss-footer__slogan">Ancient Wisdom for the Modern Muse.</p>
        <p class="ss-footer__slogan">献给现代缪斯的东方智慧。</p>
      </div>
      
      <!-- Column 2: Navigation Links -->
      <div class="ss-footer__col">
        <h4 class="ss-footer__title">Explore</h4>
        <ul class="ss-footer__links">
          <li><a href="/collections/all">Shop</a></li>
          <li><a href="https://silkandsage.co/quiz">Quiz</a></li>
          <li><a href="https://silkandsage.co/about">About</a></li>
        </ul>
      </div>
      
      <!-- Column 3: Legal Links -->
      <div class="ss-footer__col">
        <h4 class="ss-footer__title">Legal</h4>
        <ul class="ss-footer__links">
          <li><a href="https://silkandsage.co/privacy">Privacy</a></li>
          <li><a href="https://silkandsage.co/terms">Terms</a></li>
        </ul>
      </div>
    </div>
    
    <div class="ss-footer__bottom">
      <p>&copy; {{ 'now' | date: "%Y" }} Silk & Sage. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
.ss-footer {
  background-color: var(--ss-color-background);
  border-top: 1px solid rgba(138, 154, 91, 0.15);
  padding: 5rem 0 3rem;
  margin-top: 5rem;
  color: var(--ss-color-primary);
}

.ss-footer__grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 4rem;
}

.ss-footer__logo {
  font-family: var(--ss-font-serif);
  color: var(--ss-color-primary);
  font-size: 1.5rem;
  margin-bottom: 1.2rem;
  font-weight: 700;
}

.ss-footer__slogan {
  font-size: 0.9rem;
  color: #555;
  margin: 0.3rem 0;
  line-height: 1.6;
}

.ss-footer__title {
  font-family: var(--ss-font-serif);
  color: var(--ss-color-primary);
  font-size: 1.1rem;
  margin-bottom: 1.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.ss-footer__links {
  list-style: none;
  padding: 0;
  margin: 0;
}

.ss-footer__links li {
  margin-bottom: 0.9rem;
}

.ss-footer__links a {
  color: #555;
  text-decoration: none;
  font-size: 0.95rem;
  transition: var(--ss-transition);
}

.ss-footer__links a:hover {
  color: var(--ss-color-primary);
  padding-left: 4px;
}

.ss-footer__bottom {
  margin-top: 5rem;
  padding-top: 2.5rem;
  border-top: 1px solid rgba(138, 154, 91, 0.1);
  text-align: center;
  font-size: 0.85rem;
  color: #888;
}

@media (max-width: 992px) {
  .ss-footer__grid {
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 2rem;
  }
}

@media (max-width: 768px) {
  .ss-footer__grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .ss-footer {
    padding: 4rem 0 2rem;
  }
}
</style>
